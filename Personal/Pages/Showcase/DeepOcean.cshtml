@page
@model Personal.Pages.Showcase.DeepOceanModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Deep Ocean — Style Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Inter', sans-serif; background: #000; }
        canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }
        .overlay {
            position: fixed; inset: 0; z-index: 10;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center; padding: 2rem; pointer-events: none;
        }
        .badge {
            pointer-events: auto; margin-bottom: 1.5rem;
            display: inline-flex; align-items: center; gap: 10px;
            padding: 7px 20px; background: rgba(6,182,212,0.06);
            backdrop-filter: blur(14px); border: 1px solid rgba(6,182,212,0.15);
            border-radius: 50px; animation: fdw .6s ease-out forwards; opacity: 0;
        }
        .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #06b6d4; box-shadow: 0 0 8px rgba(6,182,212,0.7); animation: pulse 2s ease-in-out infinite; }
        .badge-txt { font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(6,182,212,0.7); font-weight: 500; }
        h1 { font-size: clamp(2.8rem,7vw,5.5rem); font-weight: 800; letter-spacing: -.03em; color: #fff; line-height: 1.08; max-width: 900px; margin-bottom: 1.25rem; animation: blur 1s ease-out .15s forwards; opacity: 0; }
        .accent { background: linear-gradient(135deg, #22d3ee, #3b82f6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .sub { font-size: clamp(1rem,2vw,1.2rem); color: rgba(255,255,255,0.4); max-width: 560px; line-height: 1.7; font-weight: 300; margin-bottom: 2.5rem; animation: fup .7s ease-out .45s forwards; opacity: 0; }
        .btns { pointer-events: auto; display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; animation: fup .6s ease-out .65s forwards; opacity: 0; }
        .bp { padding: 14px 36px; background: linear-gradient(135deg, #0891b2, #1d4ed8); color: #fff; border: none; border-radius: 14px; font-size: .95rem; font-weight: 700; cursor: pointer; box-shadow: 0 4px 24px rgba(8,145,178,0.3); transition: .3s; text-decoration: none; font-family: inherit; }
        .bp:hover { box-shadow: 0 8px 40px rgba(8,145,178,0.5); transform: translateY(-2px); }
        .bo { padding: 14px 36px; background: transparent; color: rgba(255,255,255,0.6); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; font-size: .95rem; font-weight: 500; cursor: pointer; backdrop-filter: blur(12px); transition: .3s; text-decoration: none; font-family: inherit; }
        .bo:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); color: #fff; }
        .stats { pointer-events: auto; margin-top: 3.5rem; display: flex; gap: 3rem; animation: fup .5s ease-out .85s forwards; opacity: 0; }
        .sv { display: block; font-size: 1.5rem; font-weight: 700; color: #fff; letter-spacing: -.02em; }
        .sl { font-size: .68rem; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: .1em; margin-top: 4px; }
        @@keyframes blur { from { opacity:0; filter:blur(16px); transform:translateY(24px) scale(1.04); } to { opacity:1; filter:blur(0); transform:translateY(0) scale(1); } }
        @@keyframes fup { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes fdw { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:.5; } }
        @@media (max-width:640px) { .btns { flex-direction:column; align-items:center; } .stats { gap:1.5rem; } }
    </style>
</head>
<body>
    <canvas id="c"></canvas>
    <div class="overlay">
        <div class="badge"><span class="badge-dot"></span><span class="badge-txt">Underwater Caustics</span></div>
        <h1>Descend into<br><span class="accent">the abyss.</span></h1>
        <p class="sub">Underwater caustic light patterns, volumetric god rays, bioluminescent particles, and abyssal depth fog. All procedural GLSL.</p>
        <div class="btns">
            <a href="#" class="bp">Dive Deeper</a>
            <a href="#" class="bo">View Source</a>
        </div>
        <div class="stats">
            <div><span class="sv">Caustics</span><span class="sl">Light Pattern</span></div>
            <div><span class="sv">God Rays</span><span class="sl">Volumetric</span></div>
            <div><span class="sv">60fps</span><span class="sl">Real-time</span></div>
        </div>
    </div>
    <script>
    (function () {
        const c = document.getElementById('c');
        const gl = c.getContext('webgl2');
        if (!gl) return;
        function resize() {
            const d = Math.max(1, 0.75 * devicePixelRatio);
            c.width = innerWidth * d; c.height = innerHeight * d;
            gl.viewport(0, 0, c.width, c.height);
        }
        addEventListener('resize', resize); resize();

        const vs = `#version 300 es
            in vec4 position;
            void main() { gl_Position = position; }`;

        const fs = `#version 300 es
            precision highp float;
            out vec4 O;
            uniform vec2 resolution;
            uniform float time;

            #define PI 3.14159265

            float hash(vec2 p) {
                vec3 p3 = fract(vec3(p.xyx) * 0.1031);
                p3 += dot(p3, p3.yzx + 33.33);
                return fract((p3.x + p3.y) * p3.z);
            }
            float hash3(vec3 p) {
                p = fract(p * 0.3183099 + 0.1);
                p *= 17.0;
                return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
            }

            float noise(vec2 p) {
                vec2 i = floor(p), f = fract(p);
                float a = hash(i), b = hash(i + vec2(1, 0)),
                      c = hash(i + vec2(0, 1)), d = hash(i + vec2(1, 1));
                vec2 u = f * f * (3.0 - 2.0 * f);
                return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
            }

            // Caustic pattern — overlapping wave interference
            float caustic(vec2 p, float t) {
                float v = 0.0;
                // Multiple wave layers at different angles
                for (int i = 0; i < 3; i++) {
                    float fi = float(i);
                    float angle = fi * PI / 3.0 + t * 0.1;
                    float cs = cos(angle), sn = sin(angle);
                    vec2 rp = vec2(p.x * cs - p.y * sn, p.x * sn + p.y * cs);
                    float wave = sin(rp.x * 6.0 + t * (0.8 + fi * 0.2)) * 0.5 + 0.5;
                    wave *= sin(rp.y * 4.5 - t * (0.6 + fi * 0.15)) * 0.5 + 0.5;
                    // Add noise turbulence
                    wave += noise(rp * 3.0 + t * 0.2) * 0.2;
                    v += wave;
                }
                v /= 3.0;
                // Sharpen the caustic lines
                v = pow(v, 3.0) * 4.0;
                return v;
            }

            // God ray — vertical light shaft
            float godRay(vec2 uv, float x, float width, float t) {
                float dist = abs(uv.x - x);
                float ray = exp(-dist * dist / (width * width));
                // Animate sway
                ray *= smoothstep(0.0, 0.8, uv.y);
                // Fade at bottom
                ray *= smoothstep(1.0, 0.3, uv.y);
                return ray;
            }

            void main() {
                vec2 uv = gl_FragCoord.xy / resolution;
                vec2 centered = (gl_FragCoord.xy - 0.5 * resolution) / resolution.y;
                float t = time;

                // Depth gradient: lighter blue at top → deep navy → near-black
                vec3 shallow = vec3(0.02, 0.12, 0.18);
                vec3 mid = vec3(0.01, 0.04, 0.1);
                vec3 deep = vec3(0.002, 0.005, 0.025);
                vec3 col;
                if (uv.y > 0.5)
                    col = mix(mid, shallow, (uv.y - 0.5) * 2.0);
                else
                    col = mix(deep, mid, uv.y * 2.0);

                // Caustic light pattern — stronger near top (closer to surface)
                float caustVal = caustic(centered * 3.0, t);
                float caustFade = smoothstep(0.0, 0.7, uv.y); // stronger near top
                vec3 caustCol = vec3(0.15, 0.45, 0.5) * caustVal * caustFade * 0.3;
                col += caustCol;

                // God rays from surface
                float rays = 0.0;
                rays += godRay(uv, 0.25 + sin(t * 0.15) * 0.05, 0.08, t) * 0.6;
                rays += godRay(uv, 0.5 + sin(t * 0.12 + 1.0) * 0.04, 0.1, t) * 0.8;
                rays += godRay(uv, 0.72 + sin(t * 0.18 + 2.5) * 0.06, 0.07, t) * 0.5;
                rays += godRay(uv, 0.38 + sin(t * 0.1 + 4.0) * 0.03, 0.06, t) * 0.4;

                // Modulate rays with caustic-like variation
                float rayNoise = noise(vec2(uv.x * 8.0, t * 0.3)) * 0.4 + 0.6;
                rays *= rayNoise;

                vec3 rayCol = vec3(0.08, 0.3, 0.35) * rays;
                col += rayCol;

                // Bioluminescent particles
                for (int i = 0; i < 20; i++) {
                    float fi = float(i);
                    float px = hash(vec2(fi * 7.3, 1.0));
                    float py = hash(vec2(fi * 3.7, 2.0));
                    float speed = 0.02 + hash(vec2(fi, 5.0)) * 0.03;
                    float phase = hash(vec2(fi, 8.0)) * 100.0;

                    // Drift position
                    float particleX = fract(px + sin(t * speed * 2.0 + phase) * 0.1 + t * speed * 0.3);
                    float particleY = fract(py + t * speed);

                    vec2 pPos = vec2(particleX, particleY);
                    float dist = length(uv - pPos);
                    float size = 0.002 + hash(vec2(fi, 10.0)) * 0.003;
                    float brightness = smoothstep(size, 0.0, dist);

                    // Pulsing glow
                    float pulseRate = 1.5 + hash(vec2(fi, 12.0)) * 2.0;
                    brightness *= 0.5 + 0.5 * sin(t * pulseRate + phase);

                    // Color: cyan/blue/green bioluminescence
                    float hue = hash(vec2(fi, 15.0));
                    vec3 particleCol = mix(vec3(0.1, 0.6, 0.8), vec3(0.2, 0.8, 0.4), hue);
                    col += particleCol * brightness * 0.8;

                    // Soft glow halo
                    float halo = exp(-dist * 200.0) * 0.15;
                    col += particleCol * halo * (0.5 + 0.5 * sin(t * pulseRate + phase));
                }

                // Surface ripple at very top
                float ripple = noise(vec2(uv.x * 15.0 + t * 0.5, t * 0.8)) * 0.5 + 0.5;
                float surfaceBand = smoothstep(0.95, 1.0, uv.y);
                col += vec3(0.1, 0.25, 0.3) * ripple * surfaceBand * 0.5;

                // Depth fog — darkens edges and bottom
                float depthFog = smoothstep(0.6, 0.0, uv.y) * 0.4;
                col = mix(col, deep * 0.5, depthFog);

                // Vignette
                vec2 q = gl_FragCoord.xy / resolution;
                col *= 0.4 + 0.6 * pow(16.0 * q.x * q.y * (1.0 - q.x) * (1.0 - q.y), 0.2);

                // Tone map
                col = col / (1.0 + col);
                col = pow(col, vec3(0.9));

                O = vec4(col, 1.0);
            }`;

        function mk(src, type) {
            const sh = gl.createShader(type);
            gl.shaderSource(sh, src); gl.compileShader(sh);
            if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) console.error(gl.getShaderInfoLog(sh));
            return sh;
        }
        const prg = gl.createProgram();
        gl.attachShader(prg, mk(vs, gl.VERTEX_SHADER));
        gl.attachShader(prg, mk(fs, gl.FRAGMENT_SHADER));
        gl.linkProgram(prg); gl.useProgram(prg);
        const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,1,-1,-1,1,1,1,-1]), gl.STATIC_DRAW);
        const pos = gl.getAttribLocation(prg, 'position');
        gl.enableVertexAttribArray(pos);
        gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);
        const rL = gl.getUniformLocation(prg, 'resolution');
        const tL = gl.getUniformLocation(prg, 'time');
        (function draw(now) {
            gl.clearColor(0,0,0,1); gl.clear(gl.COLOR_BUFFER_BIT);
            gl.uniform2f(rL, c.width, c.height);
            gl.uniform1f(tL, now * 0.001);
            gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
            requestAnimationFrame(draw);
        })();
    })();
    </script>
</body>
</html>
