@page
@model Personal.Pages.Showcase.CyberGridModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cyber Grid — Style Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Inter', sans-serif; background: #000; }

        canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }

        .overlay {
            position: fixed; inset: 0; z-index: 10;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center; padding: 2rem;
            pointer-events: none;
        }

        .badge {
            pointer-events: auto;
            margin-bottom: 1.5rem;
            display: inline-flex; align-items: center; gap: 10px;
            padding: 7px 20px;
            background: rgba(0,255,255,0.04);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(0,255,255,0.12);
            border-radius: 50px;
            animation: fdw .6s ease-out forwards; opacity: 0;
        }
        .badge-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: #22d3ee;
            box-shadow: 0 0 8px rgba(34,211,238,0.6);
            animation: pulse 2s ease-in-out infinite;
        }
        .badge-txt {
            font-size: .7rem; letter-spacing: .14em;
            text-transform: uppercase;
            color: rgba(0,255,255,0.6); font-weight: 500;
        }

        h1 {
            font-size: clamp(2.8rem,7vw,5.5rem); font-weight: 900;
            letter-spacing: .06em; color: #fff; line-height: 1.08;
            max-width: 900px; margin-bottom: 1.25rem;
            text-transform: uppercase;
            animation: blur 1s ease-out .15s forwards; opacity: 0;
        }
        .accent {
            background: linear-gradient(90deg, #22d3ee, #f0abfc, #22d3ee);
            background-size: 200% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 3s linear infinite;
        }

        .sub {
            font-size: clamp(1rem,2vw,1.2rem);
            color: rgba(255,255,255,0.45); max-width: 580px;
            line-height: 1.7; font-weight: 300; margin-bottom: 2.5rem;
            animation: fup .7s ease-out .45s forwards; opacity: 0;
        }

        .btns {
            pointer-events: auto; display: flex; flex-wrap: wrap;
            gap: 14px; justify-content: center;
            animation: fup .6s ease-out .65s forwards; opacity: 0;
        }
        .bp {
            padding: 14px 36px;
            background: linear-gradient(90deg, #06b6d4, #22d3ee);
            color: #000; border: none; border-radius: 4px;
            font-size: .95rem; font-weight: 700; cursor: pointer;
            box-shadow: 0 0 24px rgba(6,182,212,0.4),
                0 0 60px rgba(6,182,212,0.15);
            transition: .3s; text-decoration: none; font-family: inherit;
            text-transform: uppercase; letter-spacing: .08em;
        }
        .bp:hover { box-shadow: 0 0 40px rgba(6,182,212,0.6), 0 0 80px rgba(6,182,212,0.25); transform: translateY(-2px); }
        .bo {
            padding: 14px 36px; background: transparent;
            color: rgba(0,255,255,0.7);
            border: 1px solid rgba(0,255,255,0.25);
            border-radius: 4px; font-size: .95rem; font-weight: 600;
            cursor: pointer; backdrop-filter: blur(12px);
            transition: .3s; text-decoration: none; font-family: inherit;
            text-transform: uppercase; letter-spacing: .08em;
        }
        .bo:hover { background: rgba(0,255,255,0.06); border-color: rgba(0,255,255,0.5); color: #fff; }

        .stats {
            pointer-events: auto; margin-top: 3.5rem;
            display: flex; gap: 3rem;
            animation: fup .5s ease-out .85s forwards; opacity: 0;
        }
        .sv { display: block; font-size: 1.5rem; font-weight: 700; color: #22d3ee; letter-spacing: -.02em; }
        .sl { font-size: .68rem; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: .1em; margin-top: 4px; }

        @@keyframes blur {
            from { opacity: 0; filter: blur(16px); transform: translateY(24px) scale(1.04); }
            to { opacity: 1; filter: blur(0); transform: translateY(0) scale(1); }
        }
        @@keyframes fup {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes fdw {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .5; } }
        @@keyframes shimmer { to { background-position: -200% 0; } }
        @@media (max-width:640px) {
            .btns { flex-direction: column; align-items: center; }
            .stats { gap: 1.5rem; }
        }
    </style>
</head>
<body>
    <canvas id="c"></canvas>
    <div class="overlay">
        <div class="badge">
            <span class="badge-dot"></span>
            <span class="badge-txt">System Online</span>
        </div>
        <h1>Enter the<br><span class="accent">digital frontier.</span></h1>
        <p class="sub">Next-gen infrastructure built on the edge.
            Zero-latency mesh networking for the post-cloud era.</p>
        <div class="btns">
            <a href="#" class="bp">Jack In</a>
            <a href="#" class="bo">View Specs</a>
        </div>
        <div class="stats">
            <div><span class="sv">10Tb/s</span><span class="sl">Bandwidth</span></div>
            <div><span class="sv">&lt;1ms</span><span class="sl">Latency</span></div>
            <div><span class="sv">256</span><span class="sl">Edge Nodes</span></div>
        </div>
    </div>

    <script>
    (function () {
        const c = document.getElementById('c');
        const gl = c.getContext('webgl2');
        if (!gl) return;

        function resize() {
            const d = Math.max(1, 0.5 * devicePixelRatio);
            c.width = innerWidth * d;
            c.height = innerHeight * d;
            gl.viewport(0, 0, c.width, c.height);
        }
        addEventListener('resize', resize);
        resize();

        const vs = `#version 300 es
            in vec4 position;
            void main() { gl_Position = position; }`;

        const fs = `#version 300 es
            precision highp float;
            out vec4 O;
            uniform vec2 resolution;
            uniform float time;

            #define PI 3.14159265

            float hash(vec2 p) {
                p = fract(p * vec2(443.8975, 397.2973));
                p += dot(p, p.yx + 19.19);
                return fract(p.x * p.y);
            }

            void main() {
                vec2 uv = (gl_FragCoord.xy - 0.5 * resolution) / resolution.y;
                float t = time;
                vec3 col = vec3(0.0);

                // Perspective grid floor
                float horizon = 0.05;
                if (uv.y < horizon) {
                    // Grid plane via perspective projection
                    float d = (horizon - uv.y);
                    float z = 0.3 / max(d, 0.001);
                    float x = uv.x * z;

                    // Scrolling grid
                    float gx = abs(fract(x * 0.5) - 0.5);
                    float gz = abs(fract(z * 0.15 - t * 0.8) - 0.5);

                    float lineX = smoothstep(0.02, 0.0, gx) * 0.5;
                    float lineZ = smoothstep(0.02, 0.0, gz) * 0.5;

                    float grid = max(lineX, lineZ);

                    // Fade with distance
                    float fade = exp(-d * 8.0);
                    float depthFade = 1.0 - smoothstep(0.0, 30.0, z);

                    // Neon cyan + magenta tinting
                    vec3 cyan = vec3(0.1, 0.9, 1.0);
                    vec3 magenta = vec3(1.0, 0.2, 0.8);
                    vec3 gridCol = mix(cyan, magenta,
                        sin(z * 0.1 + t) * 0.5 + 0.5);

                    col += grid * gridCol * fade * depthFade;

                    // Horizon glow line
                    float horizonLine = 0.003 / max(abs(d), 0.001);
                    col += horizonLine * 0.04 * cyan;
                }

                // Sky scanlines
                if (uv.y >= horizon) {
                    float scan = sin(uv.y * 300.0 + t * 2.0) * 0.5 + 0.5;
                    col += vec3(0.02, 0.01, 0.04) * scan * 0.3;

                    // Sun / vanishing point glow
                    float sunDist = length(uv - vec2(0.0, 0.15));
                    col += vec3(1.0, 0.3, 0.6) * 0.08
                        / (sunDist + 0.2);
                    col += vec3(0.1, 0.8, 1.0) * 0.02
                        / (sunDist + 0.5);

                    // Horizontal gradient bands
                    float bands = sin(uv.y * 15.0 - t * 0.3) * 0.5 + 0.5;
                    col += vec3(0.15, 0.0, 0.25) * bands * 0.08
                        * smoothstep(0.4, 0.05, uv.y - horizon);
                }

                // Vertical scanlines
                float vscan = sin(gl_FragCoord.x * 1.5) * 0.5 + 0.5;
                col *= 0.92 + 0.08 * vscan;

                // CRT vignette
                vec2 vig = gl_FragCoord.xy / resolution;
                float v = vig.x * vig.y * (1.0 - vig.x) * (1.0 - vig.y);
                col *= smoothstep(0.0, 0.06, v) * 1.2;

                // Chromatic aberration hint
                col.r *= 1.0 + 0.01 * sin(t * 5.0);
                col.b *= 1.0 + 0.01 * cos(t * 5.0 + 1.0);

                O = vec4(col, 1.0);
            }`;

        function mk(src, type) {
            const sh = gl.createShader(type);
            gl.shaderSource(sh, src);
            gl.compileShader(sh);
            return sh;
        }
        const prg = gl.createProgram();
        gl.attachShader(prg, mk(vs, gl.VERTEX_SHADER));
        gl.attachShader(prg, mk(fs, gl.FRAGMENT_SHADER));
        gl.linkProgram(prg);
        gl.useProgram(prg);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER,
            new Float32Array([-1, 1, -1, -1, 1, 1, 1, -1]), gl.STATIC_DRAW);
        const pos = gl.getAttribLocation(prg, 'position');
        gl.enableVertexAttribArray(pos);
        gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

        const rL = gl.getUniformLocation(prg, 'resolution');
        const tL = gl.getUniformLocation(prg, 'time');

        (function draw(now) {
            gl.clearColor(0, 0, 0, 1);
            gl.clear(gl.COLOR_BUFFER_BIT);
            gl.uniform2f(rL, c.width, c.height);
            gl.uniform1f(tL, now * 0.001);
            gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
            requestAnimationFrame(draw);
        })();
    })();
    </script>
</body>
</html>
