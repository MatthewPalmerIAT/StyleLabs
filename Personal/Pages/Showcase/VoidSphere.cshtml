@page
@model Personal.Pages.Showcase.VoidSphereModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Void Sphere — Style Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Inter', sans-serif; background: #000; }

        canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }

        .overlay {
            position: fixed; inset: 0; z-index: 10;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center; padding: 2rem;
            pointer-events: none;
        }

        .badge {
            pointer-events: auto;
            margin-bottom: 1.5rem;
            display: inline-flex; align-items: center; gap: 10px;
            padding: 7px 20px;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 50px;
            animation: fdw .6s ease-out forwards; opacity: 0;
        }
        .badge-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: #a78bfa;
            box-shadow: 0 0 8px rgba(167,139,250,0.6);
            animation: pulse 2s ease-in-out infinite;
        }
        .badge-txt {
            font-size: .7rem; letter-spacing: .14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5); font-weight: 500;
        }

        h1 {
            font-size: clamp(2.8rem,7vw,5.5rem); font-weight: 800;
            letter-spacing: -.03em; color: #fff; line-height: 1.08;
            max-width: 900px; margin-bottom: 1.25rem;
            animation: blur 1s ease-out .15s forwards; opacity: 0;
        }
        .accent {
            background: linear-gradient(135deg, #c4b5fd, #f0abfc, #67e8f9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sub {
            font-size: clamp(1rem,2vw,1.2rem);
            color: rgba(255,255,255,0.42); max-width: 560px;
            line-height: 1.7; font-weight: 300; margin-bottom: 2.5rem;
            animation: fup .7s ease-out .45s forwards; opacity: 0;
        }

        .btns {
            pointer-events: auto; display: flex; flex-wrap: wrap;
            gap: 14px; justify-content: center;
            animation: fup .6s ease-out .65s forwards; opacity: 0;
        }
        .bp {
            padding: 14px 36px;
            background: linear-gradient(135deg, rgba(167,139,250,0.7), rgba(139,92,246,0.9));
            color: #fff; border: none; border-radius: 14px;
            font-size: .95rem; font-weight: 600; cursor: pointer;
            box-shadow: 0 4px 24px rgba(139,92,246,0.3),
                inset 0 1px 0 rgba(255,255,255,0.15);
            transition: .3s; text-decoration: none; font-family: inherit;
        }
        .bp:hover { box-shadow: 0 8px 40px rgba(139,92,246,0.5); transform: translateY(-2px); }
        .bo {
            padding: 14px 36px; background: transparent;
            color: rgba(255,255,255,0.6);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 14px; font-size: .95rem; font-weight: 500;
            cursor: pointer; backdrop-filter: blur(12px);
            transition: .3s; text-decoration: none; font-family: inherit;
        }
        .bo:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.25); color: #fff; }

        .stats {
            pointer-events: auto; margin-top: 3.5rem;
            display: flex; gap: 3rem;
            animation: fup .5s ease-out .85s forwards; opacity: 0;
        }
        .sv { display: block; font-size: 1.5rem; font-weight: 700; color: #fff; letter-spacing: -.02em; }
        .sl { font-size: .68rem; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: .1em; margin-top: 4px; }

        @@keyframes blur {
            from { opacity: 0; filter: blur(16px); transform: translateY(24px) scale(1.04); }
            to { opacity: 1; filter: blur(0); transform: translateY(0) scale(1); }
        }
        @@keyframes fup {
            from { opacity: 0; transform: translateY(14px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes fdw {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .5; } }
        @@media (max-width:640px) {
            .btns { flex-direction: column; align-items: center; }
            .stats { gap: 1.5rem; }
        }
    </style>
</head>
<body>
    <canvas id="c"></canvas>
    <div class="overlay">
        <div class="badge">
            <span class="badge-dot"></span>
            <span class="badge-txt">Ray-marched SDF</span>
        </div>
        <h1>Beyond the<br><span class="accent">event horizon.</span></h1>
        <p class="sub">A real-time ray-marched sphere with 3D noise displacement,
            Fresnel iridescence, soft shadows, and ambient occlusion. Pure math.</p>
        <div class="btns">
            <a href="#" class="bp">Enter the Void</a>
            <a href="#" class="bo">View Source</a>
        </div>
        <div class="stats">
            <div><span class="sv">SDF</span><span class="sl">Geometry</span></div>
            <div><span class="sv">80</span><span class="sl">March Steps</span></div>
            <div><span class="sv">60fps</span><span class="sl">Real-time</span></div>
        </div>
    </div>

    <script>
    (function () {
        const c = document.getElementById('c');
        const gl = c.getContext('webgl2');
        if (!gl) return;

        function resize() {
            const d = Math.max(1, 0.35 * devicePixelRatio);
            c.width = innerWidth * d;
            c.height = innerHeight * d;
            gl.viewport(0, 0, c.width, c.height);
        }
        addEventListener('resize', resize);
        resize();

        const vs = `#version 300 es
            in vec4 position;
            void main() { gl_Position = position; }`;

        const fs = `#version 300 es
            precision highp float;
            out vec4 O;
            uniform vec2 resolution;
            uniform float time;

            #define MAX_STEPS 80
            #define MAX_DIST 40.0
            #define SURF_DIST 0.002
            #define PI 3.14159265

            // 3D value noise
            float hash(vec3 p) {
                p = fract(p * 0.3183099 + 0.1);
                p *= 17.0;
                return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
            }

            float noise3D(vec3 x) {
                vec3 i = floor(x);
                vec3 f = fract(x);
                f = f * f * (3.0 - 2.0 * f);
                return mix(mix(mix(hash(i + vec3(0, 0, 0)), hash(i + vec3(1, 0, 0)), f.x),
                               mix(hash(i + vec3(0, 1, 0)), hash(i + vec3(1, 1, 0)), f.x), f.y),
                           mix(mix(hash(i + vec3(0, 0, 1)), hash(i + vec3(1, 0, 1)), f.x),
                               mix(hash(i + vec3(0, 1, 1)), hash(i + vec3(1, 1, 1)), f.x), f.y), f.z);
            }

            float fbm3(vec3 p) {
                float v = 0.0, a = 0.5;
                mat3 rot = mat3(0.0, 0.8, 0.6, -0.8, 0.36, -0.48, -0.6, -0.48, 0.64);
                for (int i = 0; i < 3; i++) {
                    v += a * noise3D(p);
                    p = rot * p * 2.0;
                    a *= 0.5;
                }
                return v;
            }

            // SDF: sphere with 3D noise displacement
            float mapSphere(vec3 p, float t) {
                float r = 1.8;
                float disp = fbm3(p * 1.8 + t * 0.3) * 0.55;
                return length(p) - r - disp;
            }

            // SDF: ground plane
            float mapFloor(vec3 p) {
                return p.y + 3.5;
            }

            // Scene SDF
            float map(vec3 p, float t) {
                return min(mapSphere(p, t), mapFloor(p));
            }

            // Numerical gradient normal
            vec3 calcNormal(vec3 p, float t) {
                vec2 e = vec2(0.002, 0.0);
                return normalize(vec3(
                    map(p + e.xyy, t) - map(p - e.xyy, t),
                    map(p + e.yxy, t) - map(p - e.yxy, t),
                    map(p + e.yyx, t) - map(p - e.yyx, t)));
            }

            // Soft shadow
            float softShadow(vec3 ro, vec3 rd, float mint, float maxt, float k, float t) {
                float res = 1.0;
                float ph = 1e20;
                float tt = mint;
                for (int i = 0; i < 16; i++) {
                    float h = map(ro + rd * tt, t);
                    if (h < 0.002) return 0.0;
                    float y = h * h / (2.0 * ph);
                    float d = sqrt(h * h - y * y);
                    res = min(res, k * d / max(0.0, tt - y));
                    ph = h;
                    tt += h;
                    if (tt > maxt) break;
                }
                return clamp(res, 0.0, 1.0);
            }

            // AO
            float calcAO(vec3 p, vec3 n, float t) {
                float occ = 0.0;
                float sca = 1.0;
                for (int i = 0; i < 3; i++) {
                    float h = 0.02 + 0.15 * float(i);
                    float d = map(p + h * n, t);
                    occ += (h - d) * sca;
                    sca *= 0.9;
                }
                return clamp(1.0 - 3.0 * occ, 0.0, 1.0);
            }

            // HSV to RGB
            vec3 hsv2rgb(vec3 c) {
                vec3 rgb = clamp(abs(mod(c.x * 6.0 + vec3(0, 4, 2), 6.0) - 3.0) - 1.0, 0.0, 1.0);
                return c.z * mix(vec3(1.0), rgb, c.y);
            }

            void main() {
                vec2 uv = (gl_FragCoord.xy - 0.5 * resolution) / resolution.y;
                float t = time;

                // Orbiting camera
                float ca = t * 0.2;
                vec3 ro = vec3(5.5 * sin(ca), 1.5 + 0.8 * sin(t * 0.15), 5.5 * cos(ca));
                vec3 ta = vec3(0.0, -0.2, 0.0);
                vec3 ww = normalize(ta - ro);
                vec3 uu = normalize(cross(ww, vec3(0.0, 1.0, 0.0)));
                vec3 vv = cross(uu, ww);
                vec3 rd = normalize(uv.x * uu + uv.y * vv + 1.8 * ww);

                // Light
                vec3 lightDir = normalize(vec3(0.6, 0.8, -0.5));
                vec3 lightCol = vec3(1.0, 0.95, 0.9);

                // Ray march
                float d = 0.0;
                vec3 col = vec3(0.0);

                for (int i = 0; i < MAX_STEPS; i++) {
                    vec3 p = ro + rd * d;
                    float h = map(p, t);
                    if (h < SURF_DIST) {
                        vec3 n = calcNormal(p, t);

                        // Determine which surface we hit
                        float sphereDist = mapSphere(p, t);
                        float floorDist = mapFloor(p);
                        bool isSphere = sphereDist < floorDist;

                        // Fresnel
                        float fresnel = pow(1.0 - max(dot(-rd, n), 0.0), 4.0);

                        if (isSphere) {
                            // Iridescent color based on view angle + noise
                            float hue = fract(fresnel * 0.8 + noise3D(p * 2.0 + t * 0.1) * 0.3 + t * 0.05);
                            vec3 iriCol = hsv2rgb(vec3(hue, 0.6, 0.9));

                            // Diffuse + specular
                            float diff = max(dot(n, lightDir), 0.0);
                            vec3 halfDir = normalize(lightDir - rd);
                            float spec = pow(max(dot(n, halfDir), 0.0), 64.0);

                            // Shadow + AO
                            float shd = softShadow(p + n * 0.01, lightDir, 0.02, 20.0, 16.0, t);
                            float ao = calcAO(p, n, t);

                            // Base metallic look
                            vec3 baseCol = mix(vec3(0.02), iriCol, 0.5 + 0.5 * fresnel);
                            col = baseCol * diff * shd * ao * lightCol
                                + spec * shd * 1.5
                                + iriCol * fresnel * 0.6
                                + vec3(0.02, 0.01, 0.04); // ambient
                        } else {
                            // Floor: dark reflective surface
                            float diff = max(dot(n, lightDir), 0.0);
                            float shd = softShadow(p + n * 0.01, lightDir, 0.02, 20.0, 16.0, t);

                            // Checkerboard
                            float checker = mod(floor(p.x * 0.5) + floor(p.z * 0.5), 2.0);
                            vec3 floorCol = mix(vec3(0.015), vec3(0.03), checker);

                            // Fake reflection - distance-based fade
                            float reflFade = exp(-0.08 * d);
                            vec3 reflTint = vec3(0.08, 0.05, 0.15) * reflFade;

                            col = floorCol * (0.15 + diff * shd * 0.6) + reflTint;
                        }
                        break;
                    }
                    d += h;
                    if (d > MAX_DIST) break;
                }

                // Background: subtle gradient + stars
                if (d > MAX_DIST) {
                    vec2 st = uv;
                    col = mix(vec3(0.01, 0.005, 0.03), vec3(0.03, 0.01, 0.06), st.y * 0.5 + 0.5);
                    // Stars
                    float star = pow(hash(vec3(floor(uv * 400.0), 1.0)), 25.0);
                    col += star * vec3(0.8, 0.75, 1.0);
                }

                // Fog
                float fogAmount = 1.0 - exp(-0.003 * d * d);
                col = mix(col, vec3(0.01, 0.005, 0.03), fogAmount);

                // Vignette
                vec2 q = gl_FragCoord.xy / resolution;
                col *= 0.5 + 0.5 * pow(16.0 * q.x * q.y * (1.0 - q.x) * (1.0 - q.y), 0.15);

                // Tone map + gamma
                col = col / (1.0 + col);
                col = pow(col, vec3(0.85));

                O = vec4(col, 1.0);
            }`;

        function mk(src, type) {
            const sh = gl.createShader(type);
            gl.shaderSource(sh, src);
            gl.compileShader(sh);
            if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS))
                console.error(gl.getShaderInfoLog(sh));
            return sh;
        }
        const prg = gl.createProgram();
        gl.attachShader(prg, mk(vs, gl.VERTEX_SHADER));
        gl.attachShader(prg, mk(fs, gl.FRAGMENT_SHADER));
        gl.linkProgram(prg);
        gl.useProgram(prg);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER,
            new Float32Array([-1, 1, -1, -1, 1, 1, 1, -1]), gl.STATIC_DRAW);
        const pos = gl.getAttribLocation(prg, 'position');
        gl.enableVertexAttribArray(pos);
        gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

        const rL = gl.getUniformLocation(prg, 'resolution');
        const tL = gl.getUniformLocation(prg, 'time');

        (function draw(now) {
            gl.clearColor(0, 0, 0, 1);
            gl.clear(gl.COLOR_BUFFER_BIT);
            gl.uniform2f(rL, c.width, c.height);
            gl.uniform1f(tL, now * 0.001);
            gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
            requestAnimationFrame(draw);
        })();
    })();
    </script>
</body>
</html>
