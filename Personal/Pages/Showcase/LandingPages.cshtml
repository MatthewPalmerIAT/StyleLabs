        animation: lp-pil-ring-expand 5s ease-out 2.5s infinite;
    }
    @@keyframes lp-pil-ring-expand {
        0%   { width: 30px; height: 30px; opacity: 0.5; border-color: rgba(167,139,250,0.25); }
        100% { width: 200px; height: 200px; opacity: 0; border-color: rgba(82,39,255,0.05); }
    }

    /* Floating particles around the pillar */
    .lp-pil-particle {
        position: absolute;
        width: 2px; height: 2px;
        border-radius: 50%;
        background: rgba(167,139,250,0.6);
        box-shadow: 0 0 4px 1px rgba(167,139,250,0.3);
    }
    .lp-pil-p1 { top: 20%; left: 42%; animation: lp-pil-float 6s ease-in-out infinite; }
    .lp-pil-p2 { top: 45%; left: 56%; animation: lp-pil-float 5s ease-in-out 1s infinite; }
    .lp-pil-p3 { top: 60%; left: 40%; animation: lp-pil-float 7s ease-in-out 0.5s infinite; }
    .lp-pil-p4 { top: 35%; left: 58%; animation: lp-pil-float 5.5s ease-in-out 2s infinite; }
    .lp-pil-p5 { top: 70%; left: 55%; animation: lp-pil-float 4.5s ease-in-out 1.5s infinite; }

    @@keyframes lp-pil-float {
        0%, 100% { transform: translate(0, 0); opacity: 0.3; }
        25%      { transform: translate(6px, -14px); opacity: 0.9; }
        50%      { transform: translate(-4px, -24px); opacity: 0.5; }
        75%      { transform: translate(8px, -10px); opacity: 0.7; }
    }

    .lp-pil-title-text {
        text-shadow: 0 0 40px rgba(82,39,255,0.6), 0 0 80px rgba(167,139,250,0.3) !important;
    }

    /* =========================================================
       IRIDESCENT PREVIEW — rotating dark slabs with rainbow sheen
       ========================================================= */
    .lp-iri-preview {
        background: linear-gradient(145deg, #0a0a0a 0%, #141c20 50%, #0d0d0d 100%);
        overflow: hidden;
    }

    /* Slabs — angled dark rectangles with iridescent border shimmer */
    .lp-iri-slab {
        position: absolute;
        width: 10px;
        border-radius: 3px;
        background: linear-gradient(180deg, #1a1a1a 0%, #232323 50%, #1a1a1a 100%);
        border: 1px solid rgba(255,255,255,0.04);
        transform-origin: center center;
    }
    .lp-iri-s1 {
        height: 55%; top: 22%; left: 30%;
        transform: rotate3d(1, 0.2, 0, 55deg);
        border-image: linear-gradient(180deg, rgba(255,100,100,0.2), rgba(100,255,200,0.2), rgba(100,150,255,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out infinite alternate;
    }
    .lp-iri-s2 {
        height: 60%; top: 20%; left: 36%;
        transform: rotate3d(1, 0.2, 0, 48deg);
        border-image: linear-gradient(180deg, rgba(200,150,255,0.25), rgba(100,255,220,0.2), rgba(255,200,100,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 0.4s infinite alternate;
    }
    .lp-iri-s3 {
        height: 68%; top: 16%; left: 42%;
        transform: rotate3d(1, 0.2, 0, 40deg);
        border-image: linear-gradient(180deg, rgba(100,200,255,0.3), rgba(255,100,200,0.2), rgba(100,255,150,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 0.8s infinite alternate;
    }
    .lp-iri-s4 {
        height: 72%; top: 14%; left: 48%;
        transform: rotate3d(1, 0.2, 0, 30deg);
        border-image: linear-gradient(180deg, rgba(255,200,100,0.3), rgba(100,150,255,0.25), rgba(200,100,255,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 1.2s infinite alternate;
    }
    .lp-iri-s5 {
        height: 68%; top: 16%; left: 54%;
        transform: rotate3d(1, 0.2, 0, 20deg);
        border-image: linear-gradient(180deg, rgba(150,255,200,0.25), rgba(255,100,150,0.2), rgba(100,200,255,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 1.6s infinite alternate;
    }
    .lp-iri-s6 {
        height: 60%; top: 20%; left: 60%;
        transform: rotate3d(1, 0.2, 0, 10deg);
        border-image: linear-gradient(180deg, rgba(255,150,200,0.2), rgba(200,255,100,0.2), rgba(100,100,255,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 2s infinite alternate;
    }
    .lp-iri-s7 {
        height: 50%; top: 25%; left: 66%;
        transform: rotate3d(1, 0.2, 0, 0deg);
        border-image: linear-gradient(180deg, rgba(100,255,255,0.2), rgba(255,200,100,0.2), rgba(200,100,255,0.2)) 1;
        animation: lp-iri-tilt 8s ease-in-out 2.4s infinite alternate;
    }

    @@keyframes lp-iri-tilt {
        0%   { transform: rotate3d(1, 0.2, 0, 55deg) translateY(0); opacity: 0.7; }
        100% { transform: rotate3d(1, 0.2, 0, 50deg) translateY(-4px); opacity: 1; }
    }

    /* Rainbow shimmer sweep */
    .lp-iri-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            110deg,
            transparent 20%,
            rgba(255,100,100,0.04) 30%,
            rgba(100,255,200,0.04) 40%,
            rgba(100,150,255,0.04) 50%,
            rgba(200,100,255,0.04) 60%,
            transparent 70%
        );
        animation: lp-iri-sweep 5s ease-in-out infinite;
    }
    @@keyframes lp-iri-sweep {
        0%   { transform: translateX(-60%); }
        100% { transform: translateX(60%); }
    }

    .lp-iri-title-text {
        text-shadow: 0 0 30px rgba(255,255,255,0.15), 0 0 60px rgba(100,150,255,0.1) !important;
    }

    /* =========================================================
       SILK PREVIEW — flowing fabric waves
       ========================================================= */
    .lp-silk-preview {
        background: linear-gradient(145deg, #1a1a1a 0%, #2a2a2a 40%, #1e1a20 70%, #1a1a1a 100%);
        overflow: hidden;
    }

    /* Flowing silk wave bands */
    .lp-silk-wave {
        position: absolute;
        width: 200%;
        left: -50%;
        height: 1px;
        background: linear-gradient(90deg,
            transparent 0%,
            rgba(123,116,129,0.06) 15%,
            rgba(123,116,129,0.2) 35%,
            rgba(140,130,148,0.3) 50%,
            rgba(123,116,129,0.2) 65%,
            rgba(123,116,129,0.06) 85%,
            transparent 100%
        );
        box-shadow: 0 0 12px 4px rgba(123,116,129,0.06);
    }
    .lp-silk-w1 {
        top: 28%;
        animation: lp-silk-flow 7s ease-in-out infinite;
    }
    .lp-silk-w2 {
        top: 42%;
        animation: lp-silk-flow 8s ease-in-out 1.5s infinite;
        opacity: 0.7;
    }
    .lp-silk-w3 {
        top: 56%;
        animation: lp-silk-flow 6s ease-in-out 0.8s infinite;
        opacity: 0.5;
    }
    .lp-silk-w4 {
        top: 70%;
        animation: lp-silk-flow 9s ease-in-out 2.2s infinite;
        opacity: 0.3;
    }
    @@keyframes lp-silk-flow {
        0%   { transform: translateX(-8%) scaleY(1); opacity: 0.3; }
        25%  { transform: translateX(4%) scaleY(20); opacity: 0.7; }
        50%  { transform: translateX(-2%) scaleY(1); opacity: 0.4; }
        75%  { transform: translateX(6%) scaleY(14); opacity: 0.6; }
        100% { transform: translateX(-8%) scaleY(1); opacity: 0.3; }
    }

    /* Subtle diagonal sheen */
    .lp-silk-sheen {
        position: absolute; inset: 0;
        background: linear-gradient(
            135deg,
            transparent 30%,
            rgba(140,130,150,0.04) 45%,
            rgba(160,150,170,0.06) 50%,
            rgba(140,130,150,0.04) 55%,
            transparent 70%
        );
        animation: lp-silk-sheen-move 6s ease-in-out infinite alternate;
    }
    @@keyframes lp-silk-sheen-move {
        from { transform: translateX(-30%) translateY(-10%); }
        to   { transform: translateX(30%) translateY(10%); }
    }

    .lp-silk-title-text {
        text-shadow: 0 0 24px rgba(140,130,150,0.2), 0 0 50px rgba(123,116,129,0.1) !important;
    }

    /* Pixie Dust preview */
    .lp-pixie-preview {
        background: radial-gradient(ellipse at 50% 50%, #0c0a1a 0%, #000 70%);
        overflow: hidden;
    }
    .lp-pixie-particle {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        filter: blur(0.5px);
    }
    .lp-pp-1 {
        top: 30%; left: 20%;
        background: #818cf8;
        box-shadow: 0 0 8px rgba(129,140,248,0.8), 0 0 20px rgba(129,140,248,0.3);
        animation: lp-pixie-float 3s ease-in-out infinite;
    }
    .lp-pp-2 {
        top: 55%; left: 35%;
        background: #a78bfa;
        box-shadow: 0 0 8px rgba(167,139,250,0.7), 0 0 18px rgba(167,139,250,0.3);
        animation: lp-pixie-float 3.5s ease-in-out 0.4s infinite;
    }
    .lp-pp-3 {
        top: 40%; left: 60%;
        background: #c084fc;
        box-shadow: 0 0 8px rgba(192,132,252,0.7), 0 0 18px rgba(192,132,252,0.3);
        animation: lp-pixie-float 2.8s ease-in-out 0.8s infinite;
    }
    .lp-pp-4 {
        top: 65%; left: 75%;
        background: #f472b6;
        box-shadow: 0 0 8px rgba(244,114,182,0.7), 0 0 18px rgba(244,114,182,0.3);
        animation: lp-pixie-float 4s ease-in-out 0.2s infinite;
    }
    .lp-pp-5 {
        top: 25%; left: 45%;
        background: #60a5fa;
        box-shadow: 0 0 6px rgba(96,165,250,0.6);
        animation: lp-pixie-float 3.2s ease-in-out 1s infinite;
        width: 2px; height: 2px;
    }
    .lp-pp-6 {
        top: 70%; left: 50%;
        background: #818cf8;
        box-shadow: 0 0 6px rgba(129,140,248,0.5);
        animation: lp-pixie-float 3.8s ease-in-out 0.6s infinite;
        width: 2px; height: 2px;
    }
    .lp-pp-7 {
        top: 45%; left: 80%;
        background: #a78bfa;
        box-shadow: 0 0 5px rgba(167,139,250,0.5);
        animation: lp-pixie-float 2.6s ease-in-out 1.3s infinite;
        width: 2px; height: 2px;
    }
    .lp-pp-8 {
        top: 60%; left: 15%;
        background: #c084fc;
        box-shadow: 0 0 5px rgba(192,132,252,0.5);
        animation: lp-pixie-float 3.4s ease-in-out 0.9s infinite;
        width: 2px; height: 2px;
    }
    .lp-pixie-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0.15;
    }
    .lp-pg-1 {
        top: 25%; left: 30%;
        width: 200px; height: 200px;
        background: radial-gradient(circle, #6366f1, transparent 70%);
        animation: lp-pixie-glow-pulse 4s ease-in-out infinite alternate;
    }
    .lp-pg-2 {
        top: 45%; left: 55%;
        width: 160px; height: 160px;
        background: radial-gradient(circle, #c084fc, transparent 70%);
        animation: lp-pixie-glow-pulse 5s ease-in-out 1s infinite alternate;
    }
    @@keyframes lp-pixie-float {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.7; }
        25% { transform: translate(12px, -18px) scale(1.3); opacity: 1; }
        50% { transform: translate(-8px, -30px) scale(0.8); opacity: 0.4; }
        75% { transform: translate(15px, -12px) scale(1.1); opacity: 0.9; }
    }
    @@keyframes lp-pixie-glow-pulse {
        from { opacity: 0.1; transform: scale(0.9); }
        to { opacity: 0.2; transform: scale(1.1); }
    }
    .lp-pixie-title-text {
        text-shadow: 0 0 40px rgba(99,102,241,0.4), 0 0 80px rgba(192,132,252,0.2) !important;
    }

    /* =========================================================
       NEBULA PULSE PREVIEW — cosmic gas clouds with stars
       ========================================================= */
    .lp-nebula-preview {
        background: radial-gradient(ellipse at 45% 45%, #1a0530 0%, #0c0118 40%, #000 100%);
        overflow: hidden;
    }

    /* Nebula gas clouds */
    .lp-neb-cloud {
        position: absolute;
        border-radius: 50%;
        filter: blur(30px);
        mix-blend-mode: screen;
    }
    .lp-neb-cloud-1 {
        width: 220px; height: 180px;
        top: 15%; left: 20%;
        background: radial-gradient(ellipse, rgba(168,85,247,0.25) 0%, rgba(99,102,241,0.1) 50%, transparent 70%);
        animation: lp-neb-drift 10s ease-in-out infinite alternate;
    }
    .lp-neb-cloud-2 {
        width: 180px; height: 140px;
        top: 35%; left: 45%;
        background: radial-gradient(ellipse, rgba(232,121,249,0.2) 0%, rgba(168,85,247,0.08) 50%, transparent 70%);
        animation: lp-neb-drift 12s ease-in-out 2s infinite alternate-reverse;
    }
    .lp-neb-cloud-3 {
        width: 160px; height: 120px;
        top: 50%; left: 25%;
        background: radial-gradient(ellipse, rgba(56,189,248,0.15) 0%, rgba(99,102,241,0.06) 50%, transparent 70%);
        animation: lp-neb-drift 8s ease-in-out 1s infinite alternate;
    }
    @@keyframes lp-neb-drift {
        0% { transform: translate(0, 0) scale(0.9) rotate(-5deg); opacity: 0.5; }
        50% { transform: translate(15px, -10px) scale(1.1) rotate(3deg); opacity: 0.9; }
        100% { transform: translate(-10px, 8px) scale(1.0) rotate(-2deg); opacity: 0.7; }
    }

    /* Central core glow */
    .lp-neb-core {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 100px; height: 100px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(168,85,247,0.2) 0%, rgba(232,121,249,0.08) 40%, transparent 70%);
        box-shadow: 0 0 60px 20px rgba(168,85,247,0.08);
        filter: blur(15px);
        animation: lp-neb-core-pulse 4s ease-in-out infinite alternate;
    }
    @@keyframes lp-neb-core-pulse {
        from { opacity: 0.4; transform: translate(-50%, -50%) scale(0.8); }
        to { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
    }

    /* Twinkling stars */
    .lp-neb-star {
        position: absolute;
        border-radius: 50%;
        background: #fff;
    }
    .lp-neb-s1 { width: 2px; height: 2px; top: 15%; left: 12%; box-shadow: 0 0 4px rgba(255,255,255,0.8); animation: lp-neb-twinkle 2s ease-in-out infinite; }
    .lp-neb-s2 { width: 3px; height: 3px; top: 22%; left: 72%; box-shadow: 0 0 6px rgba(200,180,255,0.7); animation: lp-neb-twinkle 2.5s ease-in-out 0.3s infinite; }
    .lp-neb-s3 { width: 1.5px; height: 1.5px; top: 38%; left: 85%; box-shadow: 0 0 3px rgba(180,200,255,0.6); animation: lp-neb-twinkle 3s ease-in-out 0.7s infinite; }
    .lp-neb-s4 { width: 2px; height: 2px; top: 65%; left: 18%; box-shadow: 0 0 4px rgba(232,121,249,0.6); animation: lp-neb-twinkle 2.2s ease-in-out 1s infinite; }
    .lp-neb-s5 { width: 1px; height: 1px; top: 78%; left: 60%; box-shadow: 0 0 3px rgba(255,255,255,0.5); animation: lp-neb-twinkle 1.8s ease-in-out 0.5s infinite; }
    .lp-neb-s6 { width: 2.5px; height: 2.5px; top: 28%; left: 42%; box-shadow: 0 0 5px rgba(168,85,247,0.7); animation: lp-neb-twinkle 2.8s ease-in-out 1.3s infinite; }
    .lp-neb-s7 { width: 1.5px; height: 1.5px; top: 72%; left: 80%; box-shadow: 0 0 3px rgba(56,189,248,0.5); animation: lp-neb-twinkle 3.2s ease-in-out 0.9s infinite; }
    @@keyframes lp-neb-twinkle {
        0%, 100% { opacity: 0.3; transform: scale(0.6); }
        50% { opacity: 1; transform: scale(1.5); }
    }

    /* Slow-moving shimmer */
    .lp-neb-shimmer {
        position: absolute; inset: 0;
        background: linear-gradient(
            135deg,
            transparent 25%,
            rgba(168,85,247,0.03) 35%,
            rgba(232,121,249,0.04) 45%,
            rgba(56,189,248,0.03) 55%,
            transparent 65%
        );
        animation: lp-neb-sweep 8s ease-in-out infinite;
    }
    @@keyframes lp-neb-sweep {
        0% { transform: translateX(-70%); }
        100% { transform: translateX(70%); }
    }

    .lp-neb-title-text {
        text-shadow: 0 0 40px rgba(168,85,247,0.6), 0 0 80px rgba(232,121,249,0.3) !important;
    }

    /* =========================================================
       CYBER GRID PREVIEW — synthwave perspective grid
       ========================================================= */
    .lp-cyber-preview {
        background: #000;
        overflow: hidden;
    }

    /* Dark sky with scanline texture */
    .lp-cy-sky {
        position: absolute;
        inset: 0; bottom: 50%;
        background: linear-gradient(180deg, #020008 0%, #0a0020 40%, #150535 80%, #200845 100%);
    }
    .lp-cy-sky::after {
        content: '';
        position: absolute; inset: 0;
        background: repeating-linear-gradient(
            180deg,
            transparent 0px,
            transparent 2px,
            rgba(255,255,255,0.015) 2px,
            rgba(255,255,255,0.015) 4px
        );
    }

    /* Neon sun */
    .lp-cy-sun {
        position: absolute;
        top: 28%; left: 50%;
        transform: translateX(-50%);
        width: 80px; height: 80px;
        border-radius: 50%;
        background: linear-gradient(180deg, #ff3d9a 0%, #ff6a00 50%, #ff3d9a 100%);
        box-shadow: 0 0 40px 10px rgba(255,61,154,0.3), 0 0 80px 20px rgba(255,106,0,0.15);
        animation: lp-cy-sun-pulse 4s ease-in-out infinite alternate;
        /* Horizontal slice lines through the sun */
        -webkit-mask-image: repeating-linear-gradient(180deg, #000 0px, #000 5px, transparent 5px, transparent 8px);
        mask-image: repeating-linear-gradient(180deg, #000 0px, #000 5px, transparent 5px, transparent 8px);
    }
    @@keyframes lp-cy-sun-pulse {
        from { opacity: 0.7; transform: translateX(-50%) scale(0.95); }
        to { opacity: 1; transform: translateX(-50%) scale(1.05); }
    }

    .lp-cy-sun-flare {
        position: absolute;
        top: 30%; left: 50%;
        transform: translateX(-50%);
        width: 200px; height: 60px;
        background: radial-gradient(ellipse, rgba(255,61,154,0.15) 0%, rgba(255,106,0,0.06) 50%, transparent 70%);
        filter: blur(10px);
    }

    /* Horizon glow line */
    .lp-cy-horizon {
        position: absolute;
        top: 50%; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent 5%, rgba(34,211,238,0.6) 30%, rgba(34,211,238,0.9) 50%, rgba(34,211,238,0.6) 70%, transparent 95%);
        box-shadow: 0 0 20px 4px rgba(34,211,238,0.3), 0 0 50px 10px rgba(34,211,238,0.1);
        z-index: 1;
    }

    /* Grid floor — perspective container */
    .lp-cy-grid {
        position: absolute;
        top: 50%; left: 0; right: 0; bottom: 0;
        overflow: hidden;
        perspective: 300px;
        perspective-origin: 50% 0%;
    }

    /* Vertical grid lines */
    .lp-cy-line {
        position: absolute;
        top: 0; bottom: 0;
        width: 1px;
        background: linear-gradient(180deg, rgba(34,211,238,0.5) 0%, rgba(34,211,238,0.15) 40%, rgba(240,171,252,0.1) 80%, transparent 100%);
        transform: rotateX(55deg);
        transform-origin: top center;
    }
    .lp-cy-v1 { left: 20%; }
    .lp-cy-v2 { left: 35%; }
    .lp-cy-v3 { left: 50%; background: linear-gradient(180deg, rgba(34,211,238,0.8) 0%, rgba(34,211,238,0.25) 50%, rgba(240,171,252,0.15) 100%); }
    .lp-cy-v4 { left: 65%; }
    .lp-cy-v5 { left: 80%; }

    /* Horizontal grid lines scrolling toward viewer */
    .lp-cy-hline {
        position: absolute;
        left: 5%; right: 5%;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, rgba(34,211,238,0.3) 20%, rgba(240,171,252,0.25) 50%, rgba(34,211,238,0.3) 80%, transparent 100%);
        animation: lp-cy-scroll 2s linear infinite;
    }
    .lp-cy-h1 { animation-delay: 0s; }
    .lp-cy-h2 { animation-delay: 0.5s; }
    .lp-cy-h3 { animation-delay: 1s; }
    .lp-cy-h4 { animation-delay: 1.5s; }
    @@keyframes lp-cy-scroll {
        0% { top: 0%; opacity: 0.8; }
        100% { top: 100%; opacity: 0; }
    }

    /* Scan line sweep */
    .lp-cy-scanline {
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
            180deg,
            transparent 0px,
            transparent 3px,
            rgba(0,255,255,0.02) 3px,
            rgba(0,255,255,0.02) 6px
        );
        pointer-events: none;
        animation: lp-cy-scan-shift 0.1s steps(2) infinite;
    }
    @@keyframes lp-cy-scan-shift {
        to { background-position: 0 6px; }
    }

    .lp-cy-title-text {
        text-shadow: 0 0 40px rgba(34,211,238,0.6), 0 0 80px rgba(240,171,252,0.25) !important;
        letter-spacing: 0.18em !important;
    }

    /* =========================================================
       VOID SPHERE PREVIEW — 3D ray-marched displaced sphere
       ========================================================= */
    .lp-voidsphere-preview {
        background: radial-gradient(ellipse at 50% 55%, #0a0518 0%, #050210 40%, #000 100%);
        overflow: hidden;
    }

    /* Starfield background */
    .lp-vs-starfield {
        position: absolute; inset: 0;
        background-image:
            radial-gradient(1px 1px at 8% 15%, rgba(200,180,255,0.6), transparent),
            radial-gradient(1px 1px at 22% 68%, rgba(180,200,255,0.4), transparent),
            radial-gradient(1px 1px at 48% 10%, rgba(255,255,255,0.5), transparent),
            radial-gradient(1px 1px at 65% 42%, rgba(200,160,255,0.5), transparent),
            radial-gradient(1px 1px at 82% 75%, rgba(180,220,255,0.4), transparent),
            radial-gradient(1px 1px at 35% 88%, rgba(255,200,255,0.3), transparent),
            radial-gradient(1px 1px at 90% 20%, rgba(200,200,255,0.5), transparent),
            radial-gradient(1px 1px at 55% 55%, rgba(180,160,255,0.4), transparent);
    }

    /* Reflective floor gradient */
    .lp-vs-floor {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 35%;
        background: linear-gradient(180deg, transparent 0%, rgba(10,5,25,0.8) 30%, rgba(5,2,16,0.95) 100%);
