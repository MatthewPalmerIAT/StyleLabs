                <pre><code class="language-javascript">// Aurora Borealis — Northern Lights Shader
// Layered noise curtains, procedural stars,
// mountain silhouette, atmospheric glow

const fs = `#version 300 es
  precision highp float; out vec4 O;
  uniform vec2 resolution; uniform float time;

  // FBM for curtain density
  float fbm(vec2 p){float v=0.,a=.5;
    mat2 rot=mat2(.8,.6,-.6,.8);
    for(int i=0;i&lt;4;i++){v+=a*noise(p);
      p=rot*p*2.;a*=.5;} return v;}

  // Mountain silhouette from layered noise
  float mountain(float x){
    return noise(vec2(x*1.5,0.))*.12
      +noise(vec2(x*3.,1.))*.06
      +noise(vec2(x*7.,2.))*.03;}

  // Aurora curtain band
  vec3 aurora(vec2 uv,float t,float off,
    vec3 c1,vec3 c2){
    float wave=sin(uv.x*3.+t*.4+off)*.08
      +sin(uv.x*5.5-t*.3+off*2.)*.05
      +sin(uv.x*1.2+t*.2)*.12;
    float cy=.35+wave+off*.08;
    float dist=uv.y-cy;
    float d=fbm(vec2(uv.x*4.+t*.15+off,
      uv.y*2.-t*.1));
    d*=smoothstep(-.02,.05,dist)
      *smoothstep(.35,.05,dist);
    d*=.5+fbm(vec2(uv.x*6.+t*.2+off*3.,
      t*.05));
    return mix(c1,c2,smoothstep(0.,.2,dist))
      *d*1.8;}

  void main(){
    vec2 uv=gl_FragCoord.xy/resolution;
    float t=time;
    // Sky gradient
    vec3 col=mix(vec3(0,.01,.04),
      vec3(.02,.04,.1),uv.y);
    // 3 aurora layers
    col+=aurora(uv,t,0.,
      vec3(.1,.8,.4),vec3(.05,.5,.7));
    col+=aurora(uv,t,1.5,
      vec3(.05,.4,.7),vec3(.3,.2,.8))*.6;
    col+=aurora(uv,t,3.2,
      vec3(.2,.7,.5),vec3(.1,.3,.6))*.4;
    // Mountain mask + stars + vignette
    float mtn=mountain(uv.x);
    float mask=smoothstep(mtn+.005,mtn-.005,
      uv.y-.05);
    col=mix(col,vec3(.005,.008,.015),mask);
    col=pow(col,vec3(.9));
    O=vec4(col,1);}`;

