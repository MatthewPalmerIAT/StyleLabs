      margin-top:1.25rem;font-weight:300;line-height:1.7}
  &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;canvas id="c"&gt;&lt;/canvas&gt;
  &lt;div class="overlay"&gt;
    &lt;h1&gt;Explore the&lt;br&gt;&lt;span class="accent"&gt;infinite cosmos.&lt;/span&gt;&lt;/h1&gt;
    &lt;p class="sub"&gt;Harness the power of distributed computing
      across galaxies of data.&lt;/p&gt;
  &lt;/div&gt;
  &lt;script&gt;
  (function(){
    const c=document.getElementById('c');
    const gl=c.getContext('webgl2'); if(!gl) return;
    function resize(){const d=Math.max(1,.5*devicePixelRatio);
      c.width=innerWidth*d;c.height=innerHeight*d;
      gl.viewport(0,0,c.width,c.height);}
    addEventListener('resize',resize); resize();

    const vs=`#version 300 es
      in vec4 position;
      void main(){gl_Position=position;}`;

    const fs=`#version 300 es
      precision highp float; out vec4 O;
      uniform vec2 resolution; uniform float time;
      #define ITER 6

      float hash(vec2 p){
        vec3 p3=fract(vec3(p.xyx)*0.1031);
        p3+=dot(p3,p3.yzx+33.33);
        return fract((p3.x+p3.y)*p3.z);}

      float noise(vec2 p){
        vec2 i=floor(p),f=fract(p);
        float a=hash(i),b=hash(i+vec2(1,0)),
              c=hash(i+vec2(0,1)),d=hash(i+vec2(1,1));
        vec2 u=f*f*(3.0-2.0*f);
        return mix(mix(a,b,u.x),mix(c,d,u.x),u.y);}

      float fbm(vec2 p){float v=0.0,a=0.5;
        mat2 rot=mat2(.8,.6,-.6,.8);
        for(int i=0;i&lt;ITER;i++){v+=a*noise(p);
          p=rot*p*2.0;a*=.5;} return v;}

      vec3 nebula(vec2 uv,float t){
        vec2 q=vec2(fbm(uv+t*.15),
                    fbm(uv+vec2(1.7,9.2)+t*.12));
        vec2 r=vec2(fbm(uv+4.*q+vec2(1.7,9.2)+t*.1),
                    fbm(uv+4.*q+vec2(8.3,2.8)+t*.08));
        float f=fbm(uv+4.*r);
        vec3 col=vec3(0);
        col=mix(vec3(.05,.02,.12),vec3(.35,.05,.45),
          clamp(f*f*4.,0.,1.));
        col=mix(col,vec3(.1,.15,.55),clamp(q.x,0.,1.));
        col=mix(col,vec3(.55,.12,.65),clamp(pow(r.x,2.),0.,1.));
        col=mix(col,vec3(.85,.3,.95),clamp(pow(r.y*f,3.),0.,1.));
        float star=pow(hash(floor(uv*200.)),22.);
        float twinkle=sin(t*3.+hash(floor(uv*200.))*60.)*.5+.5;
        col+=star*twinkle*vec3(.9,.85,1.);
        float d=length(uv);
        col+=.015/(d+.3)*vec3(.5,.2,.8)*(.8+.2*sin(t*.5));
        return col;}

      void main(){
        vec2 uv=(gl_FragCoord.xy-.5*resolution)/resolution.y;
        float t=time;
        float a=t*.03;
        mat2 rot=mat2(cos(a),sin(a),-sin(a),cos(a));
        uv=rot*uv;
        vec3 col=nebula(uv*3.,t);
        float vig=1.-.4*length(gl_FragCoord.xy/resolution-.5);
        col*=vig;
        col=pow(col,vec3(.85));
        O=vec4(col,1);}`;

    function mk(s,t){const sh=gl.createShader(t);
      gl.shaderSource(sh,s);gl.compileShader(sh);return sh;}
    const prg=gl.createProgram();
    gl.attachShader(prg,mk(vs,gl.VERTEX_SHADER));
    gl.attachShader(prg,mk(fs,gl.FRAGMENT_SHADER));
    gl.linkProgram(prg);gl.useProgram(prg);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,
      new Float32Array([-1,1,-1,-1,1,1,1,-1]),gl.STATIC_DRAW);
    const pos=gl.getAttribLocation(prg,'position');
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos,2,gl.FLOAT,false,0,0);
    const rL=gl.getUniformLocation(prg,'resolution');
    const tL=gl.getUniformLocation(prg,'time');
    (function draw(now){gl.clearColor(0,0,0,1);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.uniform2f(rL,c.width,c.height);
      gl.uniform1f(tL,now*.001);
      gl.drawArrays(gl.TRIANGLE_STRIP,0,4);
      requestAnimationFrame(draw);})();
  })();
  &lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;</code></pre>
