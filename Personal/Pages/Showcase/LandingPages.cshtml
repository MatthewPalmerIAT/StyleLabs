                <pre><code class="language-javascript">// Plasma Vortex — Volumetric Ray-march
// 3D spiraling turbulence, density accumulation,
// temperature-based coloring, god-ray scatter

const fs = `#version 300 es
  precision highp float; out vec4 O;
  uniform vec2 resolution; uniform float time;
  #define VOL_STEPS 64
  #define MAX_DIST 30.0

  float hash(vec3 p){p=fract(p*.3183099+.1);
    p*=17.;return fract(p.x*p.y*p.z*(p.x+p.y+p.z));}
  float noise3(vec3 x){
    vec3 i=floor(x),f=fract(x);
    f=f*f*(3.-2.*f);
    return mix(
      mix(mix(hash(i),hash(i+vec3(1,0,0)),f.x),
          mix(hash(i+vec3(0,1,0)),
              hash(i+vec3(1,1,0)),f.x),f.y),
      mix(mix(hash(i+vec3(0,0,1)),
              hash(i+vec3(1,0,1)),f.x),
          mix(hash(i+vec3(0,1,1)),
              hash(i+vec3(1,1,1)),f.x),f.y),f.z);}

  mat2 rot(float a){float s=sin(a),c=cos(a);
    return mat2(c,-s,s,c);}

  // Spiraling ridged turbulence
  float turbulence(vec3 p,float t){
    float v=0.,a=.5;
    p.xz=rot(p.y*.6+t*.4)*p.xz;
    for(int i=0;i&lt;5;i++){
      float n=noise3(p+t*.15*float(i+1)*.3);
      v+=a*abs(n*2.-1.);
      p=p*2.1+vec3(0,t*.1,0);
      p.xz=rot(.45)*p.xz; a*=.5;}
    return v;}

  // Volume density with radial &amp; vertical falloff
  float density(vec3 p,float t){
    float r=length(p.xz);
    float falloff=exp(-r*r*.25);
    float yFade=smoothstep(6.,0.,abs(p.y));
    float coreTwist=1.+2.*exp(-r*r);
    vec3 tp=p;
    tp.xz=rot(p.y*.3*coreTwist+t*.5)*tp.xz;
    float turb=turbulence(tp*.8,t);
    float d=turb*falloff*yFade;
    d-=.15*exp(-r*r*8.);
    return max(d,0.);}

  void main(){
    vec2 uv=(gl_FragCoord.xy-.5*resolution)
      /resolution.y;
    float t=time;
    // Orbiting camera
    float ca=t*.15;
    vec3 ro=vec3(8.*sin(ca),
      2.+sin(t*.1),8.*cos(ca));
    vec3 ww=normalize(vec3(0,1,0)-ro);
    vec3 uu=normalize(cross(ww,vec3(0,1,0)));
    vec3 vv=cross(uu,ww);
    vec3 rd=normalize(uv.x*uu+uv.y*vv+1.6*ww);

    // Accumulate volume
    vec3 col=vec3(0); float tr=1.;
    float step=(MAX_DIST-.1)/float(VOL_STEPS);
    for(int i=0;i&lt;VOL_STEPS;i++){
      float tt=.1+(float(i)+.5)*step;
      vec3 p=ro+rd*tt;
      float d=density(p,t);
      if(d&gt;.001){
        float r=length(p.xz);
        float temp=d*exp(-r*.4);
        // Temperature -> color
        vec3 hot=mix(vec3(1,.6,.1),
          vec3(1,.95,.8),temp*2.);
        vec3 warm=mix(vec3(.9,.15,.05),
          vec3(1,.5,.05),temp);
        vec3 cool=mix(vec3(.15,.02,.25),
          vec3(.6,.05,.2),temp);
        vec3 em=temp&gt;.4
          ? mix(warm,hot,(temp-.4)/.6)
          : mix(cool,warm,temp/.4);
        float ab=d*step*3.;
        col+=em*ab*tr*4.;
        tr*=exp(-ab*1.5);
        if(tr&lt;.01) break;}}

    // BG + stars + god rays + vignette
    vec3 bg=mix(vec3(.01,.005,.02),
      vec3(.02,.008,.05),uv.y*.5+.5);
    bg+=pow(hash(vec3(floor(uv*350.),7.)),28.)
      *vec3(.7,.65,.9)*tr;
    col+=bg*tr;

    vec2 q=gl_FragCoord.xy/resolution;
    col*=.5+.5*pow(16.*q.x*q.y
      *(1.-q.x)*(1.-q.y),.12);
    col=col/(1.+col);
    col=pow(col,vec3(.9));
    O=vec4(col,1);}`;

// Compile, link, set uniforms, rAF loop
// Full source on the live demo page</code></pre>
