                <pre><code class="language-javascript">// Deep Ocean — Underwater Caustics Shader
// Wave interference caustics, volumetric god rays,
// bioluminescent particles, depth fog

const fs = `#version 300 es
  precision highp float; out vec4 O;
  uniform vec2 resolution; uniform float time;
  #define PI 3.14159265

  // Caustic: 3-layer wave interference
  float caustic(vec2 p,float t){
    float v=0.;
    for(int i=0;i&lt;3;i++){
      float fi=float(i);
      float a=fi*PI/3.+t*.1;
      float cs=cos(a),sn=sin(a);
      vec2 rp=vec2(p.x*cs-p.y*sn,
        p.x*sn+p.y*cs);
      float w=sin(rp.x*6.+t*(.8+fi*.2))
        *.5+.5;
      w*=sin(rp.y*4.5-t*(.6+fi*.15))
        *.5+.5;
      w+=noise(rp*3.+t*.2)*.2;
      v+=w;}
    return pow(v/3.,3.)*4.;}

  // God ray vertical shaft
  float godRay(vec2 uv,float x,float w){
    float d=abs(uv.x-x);
    float r=exp(-d*d/(w*w));
    r*=smoothstep(0.,.8,uv.y)
      *smoothstep(1.,.3,uv.y);
    return r;}

  void main(){
    vec2 uv=gl_FragCoord.xy/resolution;
    vec2 ct=(gl_FragCoord.xy-.5*resolution)
      /resolution.y;
    float t=time;
    // Depth gradient
    vec3 col=uv.y&gt;.5
      ? mix(vec3(.01,.04,.1),vec3(.02,.12,.18),
          (uv.y-.5)*2.)
      : mix(vec3(.002,.005,.025),
          vec3(.01,.04,.1),uv.y*2.);
    // Caustics near surface
    float cv=caustic(ct*3.,t);
    col+=vec3(.15,.45,.5)*cv
      *smoothstep(0.,.7,uv.y)*.3;
    // God rays
    float rays=0.;
    rays+=godRay(uv,.25+sin(t*.15)*.05,.08)*.6;
    rays+=godRay(uv,.5+sin(t*.12+1.)*.04,.1)*.8;
    rays+=godRay(uv,.72+sin(t*.18+2.5)*.06,
      .07)*.5;
    col+=vec3(.08,.3,.35)*rays
      *(noise(vec2(uv.x*8.,t*.3))*.4+.6);
    // 20 bioluminescent particles + depth fog
    // ... (full source on live demo page)
    col=col/(1.+col);
    col=pow(col,vec3(.9));
    O=vec4(col,1);}`;

