        interaction — fluid, tactile, and alive.
        Designed for creators who see beauty
        in motion.&lt;/p&gt;
      &lt;div class="btns ac"&gt;
        &lt;a href="#" class="bp"&gt;Explore the Canvas&lt;/a&gt;
        &lt;a href="#" class="bo"&gt;Learn More&lt;/a&gt;
      &lt;/div&gt;
      &lt;ul class="micro am"&gt;
        &lt;li&gt;&lt;span class="md"&gt;&lt;/span&gt;
          Immersive shader landscapes&lt;/li&gt;
        &lt;li&gt;&lt;span class="md"&gt;&lt;/span&gt;
          Hand-tuned motion easing&lt;/li&gt;
        &lt;li&gt;&lt;span class="md"&gt;&lt;/span&gt;
          Responsive, tactile feedback&lt;/li&gt;
      &lt;/ul&gt;
    &lt;/div&gt;
  &lt;/section&gt;

  &lt;script&gt;
  (function(){
    const c = document.getElementById("c");
    const gl = c.getContext("webgl2");
    if (!gl) return;

    // Resize canvas to fill viewport
    function resize() {
      const d = Math.max(1, 0.5 * devicePixelRatio);
      c.width  = innerWidth * d;
      c.height = innerHeight * d;
      gl.viewport(0, 0, c.width, c.height);
    }
    addEventListener("resize", resize);
    resize();

    // Vertex shader — full-screen quad
    const vs = `#version 300 es
      in vec4 position;
      void main() { gl_Position = position; }`;

    // Fragment shader — green swirl
    const fs = `#version 300 es
      precision highp float;
      out vec4 O;
      uniform vec2 resolution;
      uniform float time;

      vec2 toPolar(vec2 p) {
        return vec2(length(p), atan(p.y, p.x));
      }

      void main() {
        vec2 fc = gl_FragCoord.xy;
        vec2 p = 6.0 * ((fc - 0.5 * resolution)
          / resolution.y);
        vec2 pol = toPolar(p);
        float r = pol.x;
        vec2 i = p;
        float c = 0.0;
        float ut = time * 0.5;
        float rot = r + ut + p.x * 0.1;

        for (float n = 0.0; n &lt; 4.0; n++) {
          float rr = r
            + 0.15 * sin(ut*0.7 + n + r*2.0);
          p *= mat2(
            cos(rot - sin(ut/10.0)), sin(rot),
            -sin(cos(rot) - ut/10.0), cos(rot)
          ) * -0.25;
          float t = r - ut / (n + 30.0);
          i -= p + sin(t - i.y) + rr;
          c += 2.2 / length(vec2(
            sin(i.x+t) / 0.15,
            cos(i.y+t) / 0.15));
        }
        c /= 8.0;

        vec3 base = vec3(0.2, 0.7, 0.5);
        O = vec4(
          base * smoothstep(0.0, 1.0, c * 0.6),
          1.0);
      }`;

    // Compile &amp; link
    function mk(src, type) {
      const sh = gl.createShader(type);
      gl.shaderSource(sh, src);
      gl.compileShader(sh);
      return sh;
    }
    const prg = gl.createProgram();
    gl.attachShader(prg,mk(vs,gl.VERTEX_SHADER));
    gl.attachShader(prg,mk(fs,gl.FRAGMENT_SHADER));
    gl.linkProgram(prg);
    gl.useProgram(prg);

    // Full-screen quad geometry
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER,
      new Float32Array([-1,1,-1,-1,1,1,1,-1]),
      gl.STATIC_DRAW);
    const pos = gl.getAttribLocation(prg,"position");
    gl.enableVertexAttribArray(pos);
    gl.vertexAttribPointer(pos,2,gl.FLOAT,false,0,0);

    // Uniforms
    const rL = gl.getUniformLocation(prg,"resolution");
    const tL = gl.getUniformLocation(prg,"time");

    // Render loop
    (function draw(now) {
      gl.clearColor(0, 0, 0, 1);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.uniform2f(rL, c.width, c.height);
      gl.uniform1f(tL, now * 0.001);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      requestAnimationFrame(draw);
    })();
  })();
  &lt;/script&gt;
