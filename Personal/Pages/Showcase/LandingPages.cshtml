                <pre><code class="language-javascript">// Void Sphere — WebGL2 Ray-marched SDF
// 3D FBM displacement, Fresnel iridescence,
// soft shadows, ambient occlusion, orbiting camera

const fs = `#version 300 es
  precision highp float; out vec4 O;
  uniform vec2 resolution; uniform float time;
  #define MAX_STEPS 80
  #define MAX_DIST 40.0
  #define SURF_DIST 0.002

  // 3D value noise
  float hash(vec3 p){p=fract(p*.3183099+.1);
    p*=17.;return fract(p.x*p.y*p.z*(p.x+p.y+p.z));}
  float noise3D(vec3 x){
    vec3 i=floor(x),f=fract(x);
    f=f*f*(3.-2.*f);
    return mix(
      mix(mix(hash(i),hash(i+vec3(1,0,0)),f.x),
          mix(hash(i+vec3(0,1,0)),
              hash(i+vec3(1,1,0)),f.x),f.y),
      mix(mix(hash(i+vec3(0,0,1)),
              hash(i+vec3(1,0,1)),f.x),
          mix(hash(i+vec3(0,1,1)),
              hash(i+vec3(1,1,1)),f.x),f.y),f.z);}

  // FBM with rotation per octave
  float fbm3(vec3 p){float v=0.,a=.5;
    mat3 rot=mat3(0,.8,.6,-.8,.36,-.48,
                  -.6,-.48,.64);
    for(int i=0;i&lt;3;i++){v+=a*noise3D(p);
      p=rot*p*2.;a*=.5;} return v;}

  // SDF: displaced sphere + floor
  float mapSphere(vec3 p,float t){
    float disp=fbm3(p*1.8+t*.3)*.55;
    return length(p)-1.8-disp;}
  float map(vec3 p,float t){
    return min(mapSphere(p,t),p.y+3.5);}

  // Normal via central differences
  vec3 calcNormal(vec3 p,float t){
    vec2 e=vec2(.002,0);
    return normalize(vec3(
      map(p+e.xyy,t)-map(p-e.xyy,t),
      map(p+e.yxy,t)-map(p-e.yxy,t),
      map(p+e.yyx,t)-map(p-e.yyx,t)));}

  // Soft shadow (penumbra)
  float softShadow(vec3 ro,vec3 rd,
    float mint,float maxt,float k,float t){
    float res=1.,ph=1e20,tt=mint;
    for(int i=0;i&lt;16;i++){
      float h=map(ro+rd*tt,t);
      if(h&lt;.002) return 0.;
      float y=h*h/(2.*ph);
      float d=sqrt(h*h-y*y);
      res=min(res,k*d/max(0.,tt-y));
      ph=h; tt+=h;
      if(tt&gt;maxt) break;}
    return clamp(res,0.,1.);}

  // Ambient occlusion
  float calcAO(vec3 p,vec3 n,float t){
    float occ=0.,sca=1.;
    for(int i=0;i&lt;3;i++){
      float h=.02+.15*float(i);
      occ+=(h-map(p+h*n,t))*sca;
      sca*=.9;}
    return clamp(1.-3.*occ,0.,1.);}

  // HSV to RGB for iridescence
  vec3 hsv2rgb(vec3 c){
    vec3 r=clamp(abs(mod(c.x*6.+vec3(0,4,2),
      6.)-3.)-1.,0.,1.);
    return c.z*mix(vec3(1),r,c.y);}

  void main(){
    vec2 uv=(gl_FragCoord.xy-.5*resolution)
      /resolution.y;
    float t=time;
    // Orbiting camera
    float ca=t*.2;
    vec3 ro=vec3(5.5*sin(ca),
      1.5+.8*sin(t*.15),5.5*cos(ca));
    vec3 ww=normalize(-ro+vec3(0,-.2,0));
    vec3 uu=normalize(cross(ww,vec3(0,1,0)));
    vec3 vv=cross(uu,ww);
    vec3 rd=normalize(uv.x*uu+uv.y*vv+1.8*ww);
    vec3 ld=normalize(vec3(.6,.8,-.5));

    // March
    float d=0.; vec3 col=vec3(0);
    for(int i=0;i&lt;MAX_STEPS;i++){
      vec3 p=ro+rd*d;
      float h=map(p,t);
      if(h&lt;SURF_DIST){
        vec3 n=calcNormal(p,t);
        float fr=pow(1.-max(dot(-rd,n),0.),4.);
        bool isSphere=mapSphere(p,t)&lt;p.y+3.5;
        if(isSphere){
          float hue=fract(fr*.8
            +noise3D(p*2.+t*.1)*.3+t*.05);
          vec3 iri=hsv2rgb(vec3(hue,.6,.9));
          float diff=max(dot(n,ld),0.);
          vec3 hd=normalize(ld-rd);
          float spec=pow(max(dot(n,hd),0.),64.);
          float shd=softShadow(
            p+n*.01,ld,.02,20.,16.,t);
          float ao=calcAO(p,n,t);
          vec3 base=mix(vec3(.02),iri,.5+.5*fr);
          col=base*diff*shd*ao
            +spec*shd*1.5
            +iri*fr*.6+vec3(.02,.01,.04);
        } else {
          float diff=max(dot(n,ld),0.);
          float shd=softShadow(
            p+n*.01,ld,.02,20.,16.,t);
          float ck=mod(floor(p.x*.5)
            +floor(p.z*.5),2.);
          vec3 fc=mix(vec3(.015),vec3(.03),ck);
          col=fc*(.15+diff*shd*.6)
            +vec3(.08,.05,.15)*exp(-.08*d);
        }
        break;}
      d+=h; if(d&gt;MAX_DIST) break;}

    // Background + stars
    if(d&gt;MAX_DIST){
      col=mix(vec3(.01,.005,.03),
        vec3(.03,.01,.06),uv.y*.5+.5);
      col+=pow(hash(vec3(floor(uv*400.),1.)),
        25.)*vec3(.8,.75,1.);}

    // Fog + vignette + tone map
    col=mix(col,vec3(.01,.005,.03),
      1.-exp(-.003*d*d));
    vec2 q=gl_FragCoord.xy/resolution;
    col*=.5+.5*pow(16.*q.x*q.y
      *(1.-q.x)*(1.-q.y),.15);
    col=col/(1.+col);
    col=pow(col,vec3(.85));
    O=vec4(col,1);}`;

