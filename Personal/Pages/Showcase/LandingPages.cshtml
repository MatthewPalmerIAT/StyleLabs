                <pre><code class="language-javascript">// Iridescent — 50 rotating rounded-rect slabs
// Three.js MeshPhysicalMaterial with iridescence

import * as THREE from 'three';

// Rounded-rect via Shape + ExtrudeGeometry
const shape = new THREE.Shape();
const r = 1; // corner radius
shape.absarc( 2,  2, r, 0,        Math.PI/2);
shape.absarc(-2,  2, r, Math.PI/2, Math.PI);
shape.absarc(-2, -2, r, Math.PI,   Math.PI*1.5);
shape.absarc( 2, -2, r, Math.PI*1.5, Math.PI*2);

const geo = new THREE.ExtrudeGeometry(shape, {
  depth: 0.3, bevelEnabled: true,
  bevelThickness: 0.05, bevelSize: 0.05,
  bevelSegments: 20, curveSegments: 20
});
geo.center();

// Iridescent physical material
const mat = new THREE.MeshPhysicalMaterial({
  color: 0x232323,
  metalness: 1.0,
  roughness: 0.3,
  iridescence: 1.0,
  iridescenceIOR: 1.3,
  iridescenceThicknessRange: [100, 400],
  specularIntensity: 1.0,
  reflectivity: 0.5,
  ior: 1.5
});

// 50 slabs in a row, each rotated
const group = new THREE.Group();
for (let i = 0; i &lt; 50; i++) {
  const m = new THREE.Mesh(geo, mat);
  m.position.set((i - 25) * 0.75, 0, 0);
  m.rotation.set((i - 10) * 0.1,
    Math.PI / 2, 0);
  group.add(m);
}
scene.add(group);

// Camera at [5, 5, 20], FOV 40
