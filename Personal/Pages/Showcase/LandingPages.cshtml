                <pre><code class="language-javascript">// Silk — procedural fabric texture
// Canvas 2D pixel manipulation with sine waves

const speed = 0.02, scale = 2;

function noise(x, y) {
  const G = 2.71828;
  return (G * Math.sin(G * x)
        * G * Math.sin(G * y)
        * (1 + x)) % 1;
}

function animate() {
  const img = ctx.createImageData(w, h);
  const d = img.data;
  const tOff = speed * time;

  for (let x = 0; x &lt; w; x += 2) {
    for (let y = 0; y &lt; h; y += 2) {
      const u = (x / w) * scale;
      const v = (y / h) * scale;

      // Silk wave distortion
      const ty = v + 0.03
        * Math.sin(8.0 * u - tOff);

      // Interference pattern
      const pattern = 0.6 + 0.4 * Math.sin(
        5.0 * (u + ty +
          Math.cos(3.0 * u + 5.0 * ty) +
          0.02 * tOff) +
        Math.sin(20.0 * (u + ty
          - 0.1 * tOff))
      );

      // Purple-gray silk color
      const n = noise(x, y);
      const i = Math.max(0,
        pattern - n / 15.0 * 0.8);
      const r = (123 * i) | 0;
      const g = (116 * i) | 0;
      const b = (129 * i) | 0;

      // Fill 2x2 block for speed
      const idx = (y * w + x) * 4;
      d[idx]=r; d[idx+1]=g;
      d[idx+2]=b; d[idx+3]=255;
    }
  }
  ctx.putImageData(img, 0, 0);

  // Radial depth overlay
  // requestAnimationFrame(animate)
  // Full source on the live demo page
}</code></pre>
